# Dependências
node_modules/

# Build / dist
dist/
build/
.vite/

# Variáveis de ambiente (chave da Anthropic mora aqui — nunca commitar)
.env
.env.local
.env.*.local

# Banco local de desenvolvimento (o real fica em OPFS, mas testes podem gerar)
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db

# Testes
coverage/
.vitest-cache/

# Estado local da ferramenta (memoria do agente, logs)
# Padrao: tudo ignorado. Allowlist EXPLICITA por arquivo nominal -
# adicionar novo arquivo em hooks/ ou agents/ exige edicao deste .gitignore.
# settings.local.json (permissoes pessoais) NAO entra; nem logs, nem cache, nem memoria.
.claude/*
!.claude/settings.json
!.claude/hooks/
.claude/hooks/*
!.claude/hooks/stop-check.mjs
!.claude/agents/
.claude/agents/*
!.claude/agents/revisor-treino.md

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
